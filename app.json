{
  "expo": {
    "name": "Tofes",
    "slug": "tofes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Tofes.png",
    "scheme": "tofes",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/Tofes.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aksis716.tofes"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Tofes_Icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Tofes.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#FFFFFF"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "13865688-d0a4-4e46-897f-955163af129d"
      }
    }
  }
}
